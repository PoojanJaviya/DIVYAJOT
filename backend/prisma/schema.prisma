// backend/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// =============================================
// USERS & AUTH
// =============================================

enum Role {
  SUPER_ADMIN
  ADMIN
  EDITOR
  VOLUNTEER_COORDINATOR
  USER
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

model User {
  id           String       @id @default(cuid())
  name         String       @db.VarChar(100)
  email        String       @unique @db.VarChar(150)
  password     String?      @db.VarChar(255)
  phone        String?      @db.VarChar(15)
  avatar       String?      @db.Text
  role         Role         @default(USER)
  provider     AuthProvider @default(LOCAL)
  googleId     String?      @unique @db.VarChar(100)
  isActive     Boolean      @default(true)
  isVerified   Boolean      @default(false)
  lastLogin    DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  donations     Donation[]
  volunteer     Volunteer?
  blogs         Blog[]
  refreshTokens RefreshToken[]

  @@index([email])
  @@index([role])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique @db.Text
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

// =============================================
// DONATIONS
// =============================================

enum DonationStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum DonationFrequency {
  ONE_TIME
  MONTHLY
  QUARTERLY
  ANNUALLY
}

enum PaymentMethod {
  RAZORPAY
  UPI
  BANK_TRANSFER
  CASH
  CHEQUE
}

model Donation {
  id                  String            @id @default(cuid())
  donorName           String            @db.VarChar(100)
  donorEmail          String            @db.VarChar(150)
  donorPhone          String?           @db.VarChar(15)
  donorPan            String?           @db.VarChar(10)
  amount              Decimal           @db.Decimal(10, 2)
  currency            String            @default("INR") @db.VarChar(3)
  frequency           DonationFrequency @default(ONE_TIME)
  paymentMethod       PaymentMethod     @default(RAZORPAY)
  status              DonationStatus    @default(PENDING)
  razorpayOrderId     String?           @unique @db.VarChar(100)
  razorpayPaymentId   String?           @unique @db.VarChar(100)
  razorpaySignature   String?           @db.VarChar(255)
  receiptNumber       String?           @unique @db.VarChar(50)
  receiptUrl          String?           @db.Text
  cause               String?           @db.VarChar(100)
  message             String?           @db.Text
  is80GEligible       Boolean           @default(true)
  taxReceiptSent      Boolean           @default(false)
  userId              String?
  user                User?             @relation(fields: [userId], references: [id])
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@index([donorEmail])
  @@index([status])
  @@index([createdAt])
  @@map("donations")
}

// =============================================
// VOLUNTEERS
// =============================================

enum VolunteerStatus {
  PENDING
  APPROVED
  REJECTED
  INACTIVE
}

model Volunteer {
  id           String          @id @default(cuid())
  userId       String          @unique
  user         User            @relation(fields: [userId], references: [id])
  fullName     String          @db.VarChar(100)
  email        String          @db.VarChar(150)
  phone        String          @db.VarChar(15)
  city         String          @db.VarChar(100)
  skills       String          @db.Text
  interests    Json
  availability String          @db.VarChar(100)
  resumeUrl    String?         @db.Text
  bio          String?         @db.Text
  status       VolunteerStatus @default(PENDING)
  approvedBy   String?         @db.VarChar(100)
  approvedAt   DateTime?
  totalHours   Int             @default(0)
  joinedAt     DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([status])
  @@index([city])
  @@map("volunteers")
}

// =============================================
// EVENTS / ACTIVITIES
// =============================================

enum EventStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

enum EventCategory {
  EDUCATION
  FOOD_DISTRIBUTION
  BHOJAN_SEVA
  WINTER_RELIEF
  HEALTH_CAMP
  WOMEN_EMPOWERMENT
  OLD_AGE_SUPPORT
  DISASTER_RELIEF
  ANIMAL_WELFARE
  COMMUNITY_CELEBRATION
  AWARENESS_CAMP
  OTHER
}

model Event {
  id               String        @id @default(cuid())
  title            String        @db.VarChar(255)
  slug             String        @unique @db.VarChar(255)
  description      String        @db.Text
  shortDesc        String?       @db.VarChar(300)
  category         EventCategory
  status           EventStatus   @default(UPCOMING)
  location         String        @db.VarChar(255)
  district         String?       @db.VarChar(100)
  state            String        @default("Gujarat") @db.VarChar(100)
  startDate        DateTime
  endDate          DateTime?
  beneficiaryCount Int?
  volunteerCount   Int?
  coverImage       String?       @db.Text
  images           Json?
  metaTitle        String?       @db.VarChar(255)
  metaDesc         String?       @db.Text
  isPublished      Boolean       @default(false)
  isFeatured       Boolean       @default(false)
  createdBy        String?       @db.VarChar(100)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([category])
  @@index([status])
  @@index([startDate])
  @@index([isPublished])
  @@map("events")
}

// =============================================
// CAUSES
// =============================================

model Cause {
  id               String   @id @default(cuid())
  name             String   @db.VarChar(100)
  slug             String   @unique @db.VarChar(100)
  description      String   @db.Text
  objectives       Json
  icon             String?  @db.VarChar(50)
  coverImage       String?  @db.Text
  totalRaised      Decimal  @default(0) @db.Decimal(12, 2)
  targetAmount     Decimal? @db.Decimal(12, 2)
  beneficiaryCount Int      @default(0)
  isActive         Boolean  @default(true)
  isFeatured       Boolean  @default(false)
  sortOrder        Int      @default(0)
  metaTitle        String?  @db.VarChar(255)
  metaDesc         String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([isActive])
  @@map("causes")
}

// =============================================
// GALLERY
// =============================================

enum MediaType {
  IMAGE
  VIDEO
}

model GalleryItem {
  id           String    @id @default(cuid())
  title        String    @db.VarChar(255)
  description  String?   @db.Text
  type         MediaType @default(IMAGE)
  url          String    @db.Text
  thumbnailUrl String?   @db.Text
  cloudinaryId String?   @db.VarChar(255)
  category     String?   @db.VarChar(100)
  eventId      String?   @db.VarChar(50)
  tags         Json?
  sortOrder    Int       @default(0)
  isPublished  Boolean   @default(true)
  isFeatured   Boolean   @default(false)
  uploadedBy   String?   @db.VarChar(100)
  capturedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([category])
  @@index([type])
  @@index([isPublished])
  @@map("gallery_items")
}

// =============================================
// BLOG
// =============================================

enum BlogStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Blog {
  id          String     @id @default(cuid())
  title       String     @db.VarChar(255)
  slug        String     @unique @db.VarChar(255)
  content     String     @db.LongText
  excerpt     String?    @db.Text
  coverImage  String?    @db.Text
  category    String?    @db.VarChar(100)
  tags        Json?
  status      BlogStatus @default(DRAFT)
  authorId    String?
  author      User?      @relation(fields: [authorId], references: [id])
  metaTitle   String?    @db.VarChar(255)
  metaDesc    String?    @db.Text
  views       Int        @default(0)
  isFeatured  Boolean    @default(false)
  publishedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  comments    Comment[]

  @@index([status])
  @@index([category])
  @@index([publishedAt])
  @@map("blogs")
}

model Comment {
  id         String   @id @default(cuid())
  blogId     String
  blog       Blog     @relation(fields: [blogId], references: [id], onDelete: Cascade)
  name       String   @db.VarChar(100)
  email      String   @db.VarChar(150)
  content    String   @db.Text
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([blogId])
  @@index([isApproved])
  @@map("comments")
}

// =============================================
// REPORTS
// =============================================

enum ReportType {
  ANNUAL_REPORT
  AUDIT_REPORT
  FINANCIAL_REPORT
  ACTIVITY_REPORT
  CERTIFICATE
  PRESS_RELEASE
}

model Report {
  id          String     @id @default(cuid())
  title       String     @db.VarChar(255)
  type        ReportType
  year        Int?
  description String?    @db.Text
  fileUrl     String     @db.Text
  fileSize    Int?
  isPublic    Boolean    @default(true)
  downloads   Int        @default(0)
  uploadedBy  String?    @db.VarChar(100)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([type])
  @@index([year])
  @@map("reports")
}

// =============================================
// CONTACT MESSAGES
// =============================================

enum ContactStatus {
  NEW
  IN_PROGRESS
  RESOLVED
  SPAM
}

model ContactMessage {
  id         String        @id @default(cuid())
  name       String        @db.VarChar(100)
  email      String        @db.VarChar(150)
  phone      String?       @db.VarChar(15)
  subject    String?       @db.VarChar(255)
  message    String        @db.Text
  status     ContactStatus @default(NEW)
  assignedTo String?       @db.VarChar(100)
  notes      String?       @db.Text
  repliedAt  DateTime?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([status])
  @@index([createdAt])
  @@map("contact_messages")
}

// =============================================
// TESTIMONIALS
// =============================================

model Testimonial {
  id          String   @id @default(cuid())
  name        String   @db.VarChar(100)
  role        String?  @db.VarChar(100)
  location    String?  @db.VarChar(100)
  message     String   @db.Text
  rating      Int      @default(5)
  avatar      String?  @db.Text
  category    String?  @db.VarChar(100)
  isPublished Boolean  @default(false)
  isFeatured  Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([isPublished])
  @@map("testimonials")
}

// =============================================
// PARTNERS
// =============================================

model Partner {
  id          String   @id @default(cuid())
  name        String   @db.VarChar(100)
  logoUrl     String?  @db.Text
  website     String?  @db.VarChar(255)
  partnerType String?  @db.VarChar(100)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  @@map("partners")
}

// =============================================
// NEWSLETTER
// =============================================

model NewsletterSubscriber {
  id              String    @id @default(cuid())
  email           String    @unique @db.VarChar(150)
  name            String?   @db.VarChar(100)
  isActive        Boolean   @default(true)
  source          String?   @db.VarChar(100)
  subscribedAt    DateTime  @default(now())
  unsubscribedAt  DateTime?

  @@index([email])
  @@map("newsletter_subscribers")
}

// =============================================
// IMPACT METRICS
// =============================================

model ImpactMetric {
  id          String   @id @default(cuid())
  label       String   @db.VarChar(100)
  value       Int
  suffix      String?  @db.VarChar(20)
  description String?  @db.Text
  iconEmoji   String?  @db.VarChar(10)
  isPublished Boolean  @default(true)
  sortOrder   Int      @default(0)
  updatedAt   DateTime @updatedAt

  @@map("impact_metrics")
}
